NODE_ENV=production
PORT=8080
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/plumtrips_hrms
JWT_SECRET=replace-with-long-random
FRONTEND_ORIGIN=https://hrms.plumtrips.com
COOKIE_DOMAIN=.plumtrips.com
AWS_REGION=ap-south-1
S3_BUCKET=plumtrips-hrms-prod
PRESIGN_TTL=900

# TBO Hotel API credentials (Basic auth — agency-specific, issued by TBO)
TBO_HOTEL_USERNAME=
TBO_HOTEL_PASSWORD=

# TBO Shared API credentials (used by Authenticate / GetBookingDetail / cancel flows — TokenId model)
TBO_ClientId=ApiIntegrationNew
TBO_UserName=
TBO_Password=

# TBO end-user IP for outbound API calls (any valid IPv4; falls back to script default if unset)
TBO_EndUserIp=

# ── Ticketing / Gmail ─────────────────────────────────────────────────────────
# Local dev: path to service account JSON (relative to apps/backend/)
GMAIL_SERVICE_ACCOUNT_KEY_PATH=secrets/plumtrips-ticketing-sa.json
# Production (App Runner): full JSON contents as a single-line string
# GMAIL_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
TICKETING_INBOX_EMAIL=booking@plumtrips.com
TICKETING_GMAIL_LABEL_PROCESSED=Plumtrips/Processed
TICKETING_CRON_ENABLED=true

# Google Gemini (also used by AI/Concierge features)
GEMINI_API_KEY=

# Pixabay API — auto-resolves city photos for the SBT landing bento (optional).
# Leave blank to disable (cards fall back to the navy placeholder). Backend-only — never expose to frontend.
PIXABAY_API_KEY=

# ── WhatsApp Cloud API — Expense Management inbound receipt capture ───────────
# Meta Graph / Cloud API path (separate from the whatsapp-web.js EOD/Sales-Pulse
# flow). All optional: when unset the webhook still boots but the capture worker
# stays idle. Required only to actually download media + send the unregistered reply.
WA_VERIFY_TOKEN=          # GET /webhook handshake token (you choose this; set the same value in Meta)
WA_APP_SECRET=            # Meta App Secret — keys X-Hub-Signature-256 verification
WA_ACCESS_TOKEN=          # Graph API bearer token for media download + replies
WA_PHONE_NUMBER_ID=       # business phone number id used to send replies
WA_GRAPH_VERSION=v21.0    # Graph API version (defaults to v21.0 if unset)

# ── Travel-intake webhook — public "PlumTrips International Travel Information
# Form" (Google Form → Apps Script → POST /api/intake/travel). HMAC-SHA256 over
# the raw body, header X-Intake-Signature. Optional INTAKE_FANOUT_MODE:
# "fanout" (default, one ManualBooking per selected service) or "single" (one
# ManualBooking, type=OTHER, full service list in metadata.services).
INTAKE_WEBHOOK_SECRET=
INTAKE_FANOUT_MODE=fanout

# ── Native public travel-request form — POST /api/public/travel-request ──────
# Cloudflare Turnstile secret key (server-side siteverify). FAIL-CLOSED: if
# unset in production the endpoint rejects every submission with 400. Only
# bypass is TURNSTILE_DEV_BYPASS=true, and only when NODE_ENV!=="production" —
# prefer Cloudflare's always-pass test keys locally over the bypass flag.
TURNSTILE_SECRET=
TURNSTILE_DEV_BYPASS=false