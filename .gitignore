# dependencies
node_modules/

# builds
dist/
build/

# EXCEPTION: the vendored @plumtrips/shared build MUST be committed — it is the
# only copy that travels into the apps/backend subtree split (the App Runner
# mirror has no monorepo workspace to build it from). Regenerate via
# scripts/vendor-shared.mjs. Keep this negation below the `dist/` rule above.
!vendor/shared/dist/
!vendor/shared/dist/**

# env
.env
.env.*
!.env.example

# logs
logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# OS
.DS_Store
Thumbs.db

# editors
.vscode/
.idea/

# uploads & runtime files
uploads/

# puppeteer / playwright cache
.cache/

# tests & coverage
coverage/

# misc
*.pdf
*.zip
backend-src-tree.txt
