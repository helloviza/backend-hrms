{
  "name": "@plumtrips/hrms-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "packageManager": "pnpm@8.15.4",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:test": "node --env-file=.env.test --import tsx src/server.ts",
    "postinstall": "npx puppeteer browsers install chrome",
    "build": "npx puppeteer browsers install chrome && tsc -p tsconfig.json && cp -r src/data dist/",
    "start": "node dist/server.js",
    "seed": "tsx src/seed/seed.ts",
    "test": "vitest",
    "deploy-check": "node scripts/deploy-check.mjs",
    "clean": "Remove-Item -Recurse -Force node_modules, pnpm-lock.yaml",
    "migrate:travel": "tsx src/scripts/migrateTravelBookings.ts"
  },
  "dependencies": {
    "@aws-sdk/client-apprunner": "^3.693.0",
    "@aws-sdk/client-s3": "^3.693.0",
    "@aws-sdk/s3-presigned-post": "^3.908.0",
    "@aws-sdk/s3-request-presigner": "^3.693.0",
    "@google-cloud/speech": "^7.2.1",
    "@google/genai": "^1.41.0",
    "@google/generative-ai": "^0.24.1",
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.11",
    "openai": "^4.0.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "puppeteer": "^24.40.0",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.5.4",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/xlsx": "^0.0.36",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}